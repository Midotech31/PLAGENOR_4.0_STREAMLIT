# .env.example
# ── PLAGENOR 4.0 — Environment Variables ─────────────────────────────────────
# Copy to .env and fill in production values.
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# Data directory (absolute path recommended for production)
PLAGENOR_DATA_DIR=./data

# Financial
PLAGENOR_VAT_RATE=0.19
PLAGENOR_BUDGET_CAP=200000.0
PLAGENOR_INV_PREFIX=GENOCLAB-INV

# SLA deadlines (calendar days)
PLAGENOR_SLA_IBTIKAR=21
PLAGENOR_SLA_GENOCLAB=14

# Session
PLAGENOR_SESSION_TIMEOUT=480
PLAGENOR_MAX_LOGIN=5
PLAGENOR_MAX_UPLOAD_MB=50

# Productivity
PLAGENOR_THROUGHPUT_CAP=0.5

# Audit
PLAGENOR_AUDIT_RETENTION=0

# SMTP (leave blank to disable email notifications)
PLAGENOR_SMTP_HOST=
PLAGENOR_SMTP_PORT=587
PLAGENOR_SMTP_USER=
PLAGENOR_SMTP_PASS=
PLAGENOR_SMTP_FROM=noreply@essbo.dz
